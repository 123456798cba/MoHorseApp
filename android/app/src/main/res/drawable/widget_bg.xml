<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 阴影层 -->
    <item
        android:left="3dp"
        android:top="3dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#18000000" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <!-- 主背景层 -->
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="3dp"
        android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FFFFFF"
                android:centerColor="#FAFCFF"
                android:endColor="#F0F4FF"
                android:angle="135" />
            <corners android:radius="24dp" />
            <stroke android:width="0.5dp" android:color="#D8DEFF" />
        </shape>
    </item>
</layer-list>